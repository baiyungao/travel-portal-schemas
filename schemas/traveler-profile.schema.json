{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baiyungao.github.io/travel-portal-schemas/schemas/traveler-profile.schema.json",
  "title": "TravelerProfileDocument",
  "description": "Opt-in traveler profile built from onboarding answers and story extraction. Formalized from raw/travel-planning/profiling/ben-gao.yml; provenance records which fields were stated vs inferred.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profileId",
    "userId",
    "locale",
    "travelDocuments",
    "interests",
    "constraints",
    "consent"
  ],
  "properties": {
    "profileId": { "type": "string", "minLength": 1 },
    "userId": { "type": "string", "minLength": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "locale": { "$ref": "#/$defs/locale" },
    "travelDocuments": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nationalityCountryCode", "passportCountryCode"],
      "properties": {
        "nationalityCountryCode": { "$ref": "#/$defs/countryCode" },
        "passportCountryCode": { "$ref": "#/$defs/countryCode" }
      }
    },
    "persona": {
      "type": "object",
      "additionalProperties": false,
      "required": ["archetypes"],
      "properties": {
        "archetypes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "Persona archetypes, primary first (e.g. culture_seeker, city_explorer, nature_eco)"
        },
        "pace": { "type": "string", "enum": ["relaxed", "balanced", "packed"] }
      }
    },
    "interests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "weight"],
        "properties": {
          "category": { "type": "string", "minLength": 1 },
          "weight": { "$ref": "#/$defs/preferenceWeight" }
        }
      }
    },
    "accommodation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "starRatingMin": { "type": "integer", "minimum": 1, "maximum": 5 },
        "budgetBandPerNight": { "type": "string", "enum": ["budget", "mid-range", "upscale", "luxury"] },
        "walkabilityImportant": { "type": "boolean" }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hardConstraints", "dealbreakers"],
      "properties": {
        "hardConstraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "dealbreakers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "softPreferences": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["dimension", "value", "weight"],
            "properties": {
              "dimension": { "type": "string", "minLength": 1 },
              "value": { "type": "string", "minLength": 1 },
              "weight": { "type": "integer", "minimum": 1, "maximum": 5 }
            }
          }
        }
      }
    },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["optIn", "consentAt"],
      "properties": {
        "optIn": { "type": "boolean", "const": true },
        "consentAt": { "type": "string", "format": "date-time" }
      }
    },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "basis"],
        "properties": {
          "field": { "type": "string", "minLength": 1 },
          "basis": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "locale": { "type": "string", "enum": ["en", "zh"] },
    "preferenceWeight": { "type": "string", "enum": ["love", "interested", "neutral", "avoid"] },
    "countryCode": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO 3166-1 alpha-2 country code"
    }
  }
}
